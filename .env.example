# GroundLoop local environment template (Type-2 live eval). Copy to .env (gitignored) and fill in.
# The .env is sourced before running gloop:   set -a; . ./.env; set +a
# Placeholders only — never commit real keys, URLs, or private paths.

# --- atlas index: embeddings (OpenAI-compatible /v1/embeddings serving the pinned bge-m3) ---
export KLOOP_EMBED_BASE_URL="<https://your-gateway/v1>"
export KLOOP_EMBED_API_KEY="<your-key>"
export KLOOP_EMBED_MODEL="bge-m3"

# --- shared artifacts ---
export KLOOP_ATLAS_DB="$HOME/.groundloop/atlas.db"
export KLOOP_REGISTRY="<path/to/atlas.toml>"

# --- CodeWiki produce LLM (OpenAI-compatible chat) ---
export KLOOP_PRODUCE_BASE_URL="<https://your-gateway/v1>"
export KLOOP_PRODUCE_API_KEY="<your-key>"
export KLOOP_PRODUCE_MAIN_MODEL="<chat-model>"
export KLOOP_PRODUCE_CLUSTER_MODEL="<chat-model>"
export KLOOP_PRODUCE_FALLBACK_MODEL="<chat-model>"
export KLOOP_PRODUCE_PROVIDER="openai-compatible"
export KLOOP_PRODUCE_READY="1"

# --- CBM (installed codebase-memory-mcp, launched as a subprocess) ---
export KLOOP_CBM_READY="1"
